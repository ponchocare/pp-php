{
  "name": "ponchopay/pp-php",
  "description": "Tools to integrate PonchoPay on PHP",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "files": [
      "src/token.php",
      "src/utils.php"
    ],
    "psr-4": {
      "PonchoPay\\": "src/"
    }
  },
  "authors": [
    {
      "name": "PonchoPay",
      "email": "info@ponchopay.com"
    }
  ],
  "require": {
    "php": "^8.4",
    "symfony/http-client": "^8.0",
    "firebase/php-jwt": "^7.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.90",
    "phpunit/phpunit": "^12.0"
  },
  "extra": {
    "branch-alias": {
      "dev-main": "1.3.x-dev"
    }
  }
}
